# --- Dependencies ---
# Never commit the 'heavy' folders; they are rebuilt by 'npm install' or Docker
node_modules/
jspm_packages/
typings/

# --- Environment & Secrets ---
# Crucial: Don't leak your Irving, Texas database passwords!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Docker & Logs ---
# Keep logs out of Git to keep your repository clean
.docker-compose.override.yml
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Database & Persistence ---
# If you mount volumes locally, don't commit the actual data files
pgdata/
redisdata/
esdata/

# --- Operating System Files ---
# Clean up junk files from Windows/Mac
.DS_Store
Thumbs.db
desktop.ini

# --- IDE / Editors ---
# Personal settings for your coding environment
.vscode/
.idea/
*.sublime-project
*.sublime-workspace